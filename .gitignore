# --- PYTHON / MACHINE LEARNING (The Missing Part) ---
# 1. Virtual Environments (NEVER commit these!)
venv/
.venv/
env/
ml/venv/

# 2. Python Cache (Generated automatically, do not commit)
__pycache__/
*.py[cod]
*$py.class

# 3. Data (Keep your repo light)
# We usually ignore the whole data folder because CSVs can be large.
# You can comment these out if your data is very small (<50MB).
ml/data/
ml/data/raw/
ml/data/processed/

# 4. Trained Models (Binary files)
# These are often too large for GitHub.
*.pkl
*.h5
*.pt
ml/models/

# 5. Jupyter Notebook Checkpoints
.ipynb_checkpoints/